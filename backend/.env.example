PORT=4243
NODE_ENV=development

# Required — generate a long random string for production
JWT_SECRET=change-me-to-a-long-random-secret

# Supabase (Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Optional: server-side seeding / admin scripts only — never expose in the frontend
SUPABASE_SERVICE_KEY=your-service-role-key

# Comma-separated allowed browser origins (frontend URLs)
CORS_ORIGINS=http://localhost:4242,http://127.0.0.1:4242

# Optional: created when running `npm run seed`
ADMIN_EMAIL=admin@filmmood.app
ADMIN_PASSWORD=choose-a-strong-password
ADMIN_NAME=System Administrator
